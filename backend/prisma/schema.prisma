generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  name      String
  createdAt DateTime  @default(now())
  monitors  Monitor[]
}

model Monitor {
  id            String    @id @default(uuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  name          String
  url           String
  method        String    @default("GET")
  interval      Int       @default(60) // in seconds
  status        String    @default("PENDING") // "UP", "DOWN", "PENDING"
  failureCount  Int       @default(0)
  lastCheckedAt DateTime?
  logs          Log[]
  alerts        Alert[]
  incidents     Incident[]
}

model Log {
  id           String   @id @default(uuid())
  monitorId    String
  monitor      Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  statusCode   Int?
  responseTime Int?     // in ms
  status       String   // "UP" or "DOWN"
  createdAt    DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  type      String   @default("EMAIL")
  sentAt    DateTime @default(now())
}

model Incident {
  id           String    @id @default(uuid())
  monitorId    String
  monitor      Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  startedAt    DateTime  @default(now())
  resolvedAt   DateTime?           // null = still OPEN
  durationSecs Int?                // set on resolution
  cause        String?             // e.g. "Connection refused", "Timeout"
}
