generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  plan           String          @default("free") // "free" | "paid"
  createdAt      DateTime        @default(now())
  sources        PaymentSource[]
  failedPayments FailedPayment[]
}

model PaymentSource {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String         @default("razorpay")
  name          String?
  keyId         String
  keySecret     String
  webhookSecret String
  createdAt     DateTime       @default(now())
  events        PaymentEvent[]
}

model PaymentEvent {
  id            String        @id @default(uuid())
  sourceId      String
  source        PaymentSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  razorpayEventId String     @unique
  eventType     String
  paymentId     String
  amount        Int
  email         String
  contact       String?
  status        String
  rawData       String
  createdAt     DateTime      @default(now())
  failedPayment FailedPayment?
}

model FailedPayment {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId       String?       @unique
  event         PaymentEvent? @relation(fields: [eventId], references: [id])
  paymentId     String        @unique
  orderId       String?
  amount        Int
  currency      String        @default("INR")
  customerEmail String
  customerPhone String?
  customerName  String?
  status        String        @default("pending")
  retryCount    Int           @default(0)
  lastRetryAt   DateTime?
  nextRetryAt   DateTime?
  recoveredAt   DateTime?
  recoveredVia  String?   // "link" | "external"
  metadata      String?
  createdAt     DateTime      @default(now())
  reminders     Reminder[]
  recoveryLinks RecoveryLink[]
}

model RecoveryLink {
  id              String        @id @default(uuid())
  failedPaymentId String
  failedPayment   FailedPayment @relation(fields: [failedPaymentId], references: [id], onDelete: Cascade)
  url             String
  createdAt       DateTime      @default(now())
}

model Reminder {
  id              String        @id @default(uuid())
  failedPaymentId String
  failedPayment   FailedPayment @relation(fields: [failedPaymentId], references: [id], onDelete: Cascade)
  type            String
  dayOffset       Int
  sentAt          DateTime      @default(now())
  status          String        @default("sent")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String?
  resourceId String?
  details    String?
  createdAt  DateTime @default(now())
}
