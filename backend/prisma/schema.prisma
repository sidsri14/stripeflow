generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  name                  String?
  password              String?
  googleId              String?         @unique
  plan                  String          @default("free") // "free" | "starter" | "pro"
  createdAt             DateTime        @default(now())
  // Email verification
  emailVerified         Boolean         @default(false)
  emailVerifyToken      String?         @unique
  emailVerifyExpiry     DateTime?
  // Password reset
  passwordResetToken    String?         @unique
  passwordResetExpiry   DateTime?
  sources               PaymentSource[]
  failedPayments        FailedPayment[]
  subscriptions         Subscription[]
  brandSettings         String?         // JSON: { logoUrl, primaryColor, accentColor, companyName, emailSignature }
  brandEmailSubject     String?         // Custom recovery subject
  brandEmailTone        String?         @default("professional") // professional | friendly | urgent
}

model Subscription {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerSubscriptionId String @unique // Genericized from razorpaySubscriptionId
  provider            String   @default("razorpay")
  plan                String   // "starter" | "pro"
  status              String   @default("created") // created | authenticated | active | cancelled | completed
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model PaymentSource {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String         @default("razorpay")
  name          String?
  credentials   String         // Encrypted JSON blob containing keyId, keySecret, webhookSecret, etc.
  webhookSecret String         // Keeping this top-level for fast signature verification lookup if possible, or moving to credentials
  createdAt     DateTime       @default(now())
  events        PaymentEvent[]

  @@index([userId])
}

model PaymentEvent {
  id              String        @id @default(uuid())
  sourceId        String
  source          PaymentSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  providerEventId String        @unique // Genericized from razorpayEventId
  eventType       String
  paymentId       String
  amount          Int
  email           String
  contact         String?
  status          String
  rawData         String
  createdAt       DateTime      @default(now())
  failedPayment   FailedPayment?

  @@index([sourceId])
  @@index([paymentId])
}

model FailedPayment {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId       String?       @unique
  event         PaymentEvent? @relation(fields: [eventId], references: [id])
  paymentId     String        @unique
  orderId       String?
  amount        Int
  currency      String        @default("INR")
  customerEmail String
  customerPhone String?
  customerName  String?
  status        String        @default("pending")
  retryCount    Int           @default(0)
  lastRetryAt   DateTime?
  nextRetryAt   DateTime?
  lockedAt      DateTime?     // For advisory locking in background jobs
  recoveredAt   DateTime?
  clickCount    Int           @default(0)
  recoveredVia  String?       // "link" | "external"
  metadata      String?
  createdAt     DateTime      @default(now())
  reminders     Reminder[]
  recoveryLinks RecoveryLink[]

  @@index([userId])
  @@index([status, nextRetryAt, lockedAt])
  @@index([status, nextRetryAt]) // worker query: pending/retrying payments due for retry
  @@index([userId, status, createdAt])
}

model RecoveryLink {
  id              String        @id @default(uuid())
  failedPaymentId String
  failedPayment   FailedPayment @relation(fields: [failedPaymentId], references: [id], onDelete: Cascade)
  url             String
  expiresAt       DateTime?     // Expiration metadata for the recovery link
  createdAt       DateTime      @default(now())

  @@index([failedPaymentId])
}

model Reminder {
  id              String        @id @default(uuid())
  failedPaymentId String
  failedPayment   FailedPayment @relation(fields: [failedPaymentId], references: [id], onDelete: Cascade)
  type            String
  dayOffset       Int
  sentAt          DateTime      @default(now())
  status          String        @default("sent")

  @@index([failedPaymentId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String?
  resourceId String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([resource, resourceId])
}
