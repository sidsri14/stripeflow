generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  password              String
  plan                  String          @default("free") // "free" | "paid"
  createdAt             DateTime        @default(now())
  // Email verification
  emailVerified         Boolean         @default(false)
  emailVerifyToken      String?         @unique
  emailVerifyExpiry     DateTime?
  // Password reset
  passwordResetToken    String?         @unique
  passwordResetExpiry   DateTime?
  sources               PaymentSource[]
  failedPayments        FailedPayment[]
}

model PaymentSource {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String         @default("razorpay")
  name          String?
  keyId         String
  keySecret     String
  webhookSecret String
  createdAt     DateTime       @default(now())
  events        PaymentEvent[]

  @@index([userId])
}

model PaymentEvent {
  id              String        @id @default(uuid())
  sourceId        String
  source          PaymentSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  razorpayEventId String        @unique
  eventType       String
  paymentId       String
  amount          Int
  email           String
  contact         String?
  status          String
  rawData         String
  createdAt       DateTime      @default(now())
  failedPayment   FailedPayment?

  @@index([sourceId])
  @@index([paymentId])
}

model FailedPayment {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId       String?       @unique
  event         PaymentEvent? @relation(fields: [eventId], references: [id])
  paymentId     String        @unique
  orderId       String?
  amount        Int
  currency      String        @default("INR")
  customerEmail String
  customerPhone String?
  customerName  String?
  status        String        @default("pending")
  retryCount    Int           @default(0)
  lastRetryAt   DateTime?
  nextRetryAt   DateTime?
  lockedAt      DateTime?     // For advisory locking in background jobs
  recoveredAt   DateTime?
  recoveredVia  String?       // "link" | "external"
  metadata      String?
  createdAt     DateTime      @default(now())
  reminders     Reminder[]
  recoveryLinks RecoveryLink[]

  @@index([userId])
  @@index([status, nextRetryAt, lockedAt])
  @@index([status, nextRetryAt]) // worker query: pending/retrying payments due for retry
  @@index([userId, status, createdAt])
}

model RecoveryLink {
  id              String        @id @default(uuid())
  failedPaymentId String
  failedPayment   FailedPayment @relation(fields: [failedPaymentId], references: [id], onDelete: Cascade)
  url             String
  createdAt       DateTime      @default(now())

  @@index([failedPaymentId])
}

model Reminder {
  id              String        @id @default(uuid())
  failedPaymentId String
  failedPayment   FailedPayment @relation(fields: [failedPaymentId], references: [id], onDelete: Cascade)
  type            String
  dayOffset       Int
  sentAt          DateTime      @default(now())
  status          String        @default("sent")

  @@index([failedPaymentId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String?
  resourceId String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([resource, resourceId])
}
